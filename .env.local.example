# Sanity CMS Configuration
# Get these from https://www.sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Only needed for the seed script (not for the frontend)
# Create at: Sanity Manage → API → Tokens → Add API Token (Editor role)
SANITY_API_TOKEN=your_token_here
